# ==========================================
# ASSPP Web - 环境变量配置示例
# 复制此文件为 .env 并修改相应的值
# cp .env.example .env
# ==========================================

# ------------------------------------------
# 基础配置
# ------------------------------------------
# 主机端口映射（Docker外部访问端口）
HOST_PORT=8080

# 访问密码 - 留空表示无需密码访问
ACCESS_PASSWORD=

# ------------------------------------------
# 安全配置（强烈建议设置）
# ------------------------------------------
# 账户哈希盐值（可选，但强烈建议设置以增强安全性）
# 用于防止彩虹表攻击和跨实例枚举
# 生成方法: openssl rand -hex 32
# 注意: 一旦设置后不要更改，否则所有现有账户的 Hash 将失效
VITE_ACCOUNT_HASH_SALT=

# ------------------------------------------
# 性能配置
# ------------------------------------------
# 下载线程数（1-32，默认8）
DOWNLOAD_THREADS=8

# 最大下载文件大小（MB，0表示不限制）
MAX_DOWNLOAD_MB=0

# ------------------------------------------
# 自动清理配置
# ------------------------------------------
# 自动清理天数（0表示禁用）
AUTO_CLEANUP_DAYS=0

# 自动清理大小限制（MB，0表示禁用）
AUTO_CLEANUP_MAX_MB=0

# ------------------------------------------
# 其他配置
# ------------------------------------------
# 公共基础URL（如使用Nginx反代时设置）
PUBLIC_BASE_URL=

# 构建信息（通常由CI/CD系统自动设置）
BUILD_COMMIT=
BUILD_DATE=
